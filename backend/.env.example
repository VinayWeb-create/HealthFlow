# ─── HealthFlow Backend Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control!

# Flask
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this-now-min-32-chars

# MongoDB Atlas (replace with your actual connection string)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://myuser:mypassword@cluster0.abcde.mongodb.net/healthflow?retryWrites=true&w=majority
DB_NAME=healthflow

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-frontend-domain.com

# Port (for deployment platforms)
PORT=5000
